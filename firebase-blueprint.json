{
  "entities": {
    "siteSettings": {
      "title": "Site Settings",
      "description": "Global settings for the website",
      "type": "object",
      "properties": {
        "siteName": { "type": "string", "description": "The name of the site" },
        "heroTitle": { "type": "string", "description": "Main hero title" },
        "heroSubtitle": { "type": "string", "description": "Hero subtitle text" },
        "contactEmail": { "type": "string", "format": "email", "description": "Contact email address" },
        "contactPhone": { "type": "string", "description": "Contact phone number" }
      },
      "required": ["siteName", "heroTitle"]
    },
    "course": {
      "title": "Course",
      "description": "A course offered by the school",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Certificate", "Diploma"] },
        "mandatory": { "type": "array", "items": { "type": "number" } },
        "minUnits": { "type": "number" },
        "allowExtra": { "type": "boolean" },
        "title": { "type": "string", "description": "Display title" },
        "subtitle": { "type": "string", "description": "Display subtitle" },
        "desc": { "type": "string", "description": "Short description" },
        "mask": { "type": "string", "description": "SVG mask ID" },
        "img": { "type": "string", "description": "Image seed or URL" }
      },
      "required": ["id", "name", "type", "mandatory", "minUnits"]
    },
    "unit": {
      "title": "Unit",
      "description": "A single unit/module in a course",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "activity": {
      "title": "Activity",
      "description": "A news or event activity",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "date": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "img": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "date", "title", "content", "img"]
    },
    "tutor": {
      "title": "Tutor",
      "description": "A tutor profile",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "desc": { "type": "string" },
        "img": { "type": "string" }
      },
      "required": ["name", "role", "desc", "img"]
    },
    "testimonial": {
      "title": "Testimonial",
      "description": "A student testimonial",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "text": { "type": "string" },
        "img": { "type": "string" }
      },
      "required": ["name", "text", "img"]
    }
  },
  "firestore": {
    "/settings/global": {
      "schema": "siteSettings",
      "description": "Global site configuration"
    },
    "/courses/{courseId}": {
      "schema": "course",
      "description": "Collection of courses"
    },
    "/units/{unitId}": {
      "schema": "unit",
      "description": "Collection of units"
    },
    "/activities/{activityId}": {
      "schema": "activity",
      "description": "Collection of activities"
    },
    "/tutors/{tutorId}": {
      "schema": "tutor",
      "description": "Collection of tutors"
    },
    "/testimonials/{testimonialId}": {
      "schema": "testimonial",
      "description": "Collection of testimonials"
    }
  }
}
